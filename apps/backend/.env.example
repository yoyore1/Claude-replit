# Copy to apps/backend/.env and fill in. The .env file is gitignored.

# ── Interviewer brain (Qwen / Alibaba DashScope, OpenAI-compatible mode) ──
QWEN_API_KEY=
# International endpoint shown; use the mainland one if your key is mainland.
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
# QWEN_CHAT_PATH=/chat/completions   # only if your provider differs

# ── Builder brain (MiniMax, OpenAI-compatible mode) ──
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2
# MINIMAX_CHAT_PATH=/chat/completions

# Optional: where the project being edited lives (defaults to ../template-app)
# PROJECT_ROOT=
