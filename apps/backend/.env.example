# Copy to apps/backend/.env and fill in. The .env file is gitignored.
#
# Both brains are OpenAI-compatible. Example below uses Fireworks AI, which hosts
# both Qwen and MiniMax behind one base URL + one key (different model ids).
#
# NOTE: the host (e.g. api.fireworks.ai) must be in your environment's network
# egress allowlist, or requests return 403 "host_not_allowed".

# ── Interviewer brain (Qwen) ──
QWEN_API_KEY=fw_xxxxxxxxxxxxxxxx
QWEN_BASE_URL=https://api.fireworks.ai/inference/v1
QWEN_MODEL=accounts/fireworks/models/qwen3-4b-instruct-2507
# QWEN_CHAT_PATH=/chat/completions   # only if your provider differs

# ── Builder brain (MiniMax) ──
MINIMAX_API_KEY=fw_xxxxxxxxxxxxxxxx
MINIMAX_BASE_URL=https://api.fireworks.ai/inference/v1
MINIMAX_MODEL=accounts/fireworks/models/minimax-m3
# MINIMAX_CHAT_PATH=/chat/completions

# ── Vision/AI brain (generated apps call this via /api/ai) — Qwen3-VL on DeepInfra ──
VISION_API_KEY=di_xxxxxxxxxxxxxxxx
VISION_BASE_URL=https://api.deepinfra.com/v1/openai
VISION_MODEL=Qwen/Qwen3-VL-30B-A3B-Instruct

# ── DeepInfra media + embeddings (image gen, TTS, STT, embeddings, RAG) ──
DEEPINFRA_API_KEY=di_xxxxxxxxxxxxxxxx
IMAGE_MODEL=ByteDance/Seedream-4.5
IMAGE_SIZE=2048x2048
TTS_MODEL=hexgrad/Kokoro-82M
STT_MODEL=openai/whisper-large-v3-turbo
EMBED_MODEL=Qwen/Qwen3-Embedding-0.6B

# ── RAG store (Supabase pgvector) — fill in to enable /api/rag/* (see rag.ts SQL) ──
SUPABASE_URL=
SUPABASE_KEY=

# Optional: where the project being edited lives (defaults to ../template-app)
# PROJECT_ROOT=
